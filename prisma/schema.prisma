generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id         String      @id @default(uuid())
  email      String      @unique
  password   String
  name       String?
  role       String      @default("EMPLOYEE")
  msEntraId  String?     @unique
  managerId  String?
  auditLogs  AuditLog[]
  goalSheets GoalSheet[]
  manager    User?       @relation("ManagerToEmployee", fields: [managerId], references: [id])
  employees  User[]      @relation("ManagerToEmployee")
}

model GoalSheet {
  id         String    @id @default(uuid())
  employeeId String
  cycleYear  String
  status     String    @default("DRAFT")
  createdAt  DateTime  @default(now())
  lockedAt   DateTime?
  goals      Goal[]
  employee   User      @relation(fields: [employeeId], references: [id])
}

model Goal {
  id           String            @id @default(uuid())
  goalSheetId  String
  title        String
  description  String?
  thrustArea   String
  uomType      String
  target       Float
  weightage    Float
  isShared     Boolean           @default(false)
  parentGoalId String?
  goalSheet    GoalSheet         @relation(fields: [goalSheetId], references: [id], onDelete: Cascade)
  achievements GoalAchievement[]
}

model GoalAchievement {
  id                String   @id @default(uuid())
  goalId            String
  quarter           String
  actualAchievement Float
  status            String   @default("NOT_STARTED")
  managerComment    String?
  loggedAt          DateTime @default(now())
  goal              Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String   @id @default(uuid())
  entityId    String
  entityType  String
  action      String
  oldValues   String?
  newValues   String?
  changedById String
  timestamp   DateTime @default(now())
  changedBy   User     @relation(fields: [changedById], references: [id])
}

model CycleWindow {
  id        String   @id @default(uuid())
  period    String   @unique
  openDate  DateTime
  closeDate DateTime
}
